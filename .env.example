# TeamWork — Agent-Agnostic Collaboration Shell
# Copy this file to .env and configure.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/vteam.db

# ─── Workspace ───────────────────────────────────────────────────────────────
WORKSPACE_PATH=./workspace

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ─── External Agent API ─────────────────────────────────────────────────────
# Set a key here to protect the external API. Empty = no auth (dev mode only).
EXTERNAL_API_KEY=

# ─── Sandbox / Terminal ─────────────────────────────────────────────────────
# Container name for terminal sessions (e.g. prax-sandbox-1)
#SANDBOX_CONTAINER=
# CDP host/port for browser screencast proxy
#CHROME_CDP_HOST=sandbox
#CHROME_CDP_PORT=9223

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
