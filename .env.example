# TeamWork — Agent-Agnostic Collaboration Shell
# Copy this file to .env and configure.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/vteam.db

# ─── Workspace ───────────────────────────────────────────────────────────────
WORKSPACE_PATH=./workspace

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ─── External Agent API ─────────────────────────────────────────────────────
# Set a key here to protect the external API. Empty = no auth (dev mode only).
EXTERNAL_API_KEY=

# ─── Sandbox connection (terminal / browser / desktop) ──────────────────────
# These tell TeamWork how to reach the agent's sandbox container for the
# terminal (docker exec), browser (Chrome DevTools Protocol screencast), and
# desktop (noVNC) panels. The right values depend on WHERE TeamWork runs:
#
#   • TeamWork INSIDE Docker, same compose network as the sandbox (defaults):
#       SANDBOX_CONTAINER=<service-or-container name>
#       CHROME_CDP_HOST=sandbox            # the sandbox's Docker network hostname
#       CHROME_CDP_PORT=9223
#       DESKTOP_VNC_URL=http://sandbox:6080
#
#   • TeamWork running NATIVELY on the host, with the (split) prax-sandbox
#     compose publishing its ports on localhost — use the container name +
#     localhost. The prax-sandbox compose pins `name: prax-sandbox`, so the
#     container is deterministically `prax-sandbox-sandbox-1`, and ports are
#     published on 127.0.0.1 (9223 CDP, 6080 noVNC, 4096 OpenCode):
#       SANDBOX_CONTAINER=prax-sandbox-sandbox-1
#       CHROME_CDP_HOST=localhost
#       CHROME_CDP_PORT=9223
#       DESKTOP_VNC_URL=http://localhost:6080
#
# NOTE: Prax's `make run-local-all*` targets set these automatically for the
# native path (see the Makefile's TW_SANDBOX_ENV) — you only need them here when
# running TeamWork natively WITHOUT that Makefile. Leaving them unset falls back
# to the in-Docker defaults, which a native TeamWork can't resolve (terminal
# 404 / no session, desktop 503, browser CDP unreachable).
#SANDBOX_CONTAINER=
#CHROME_CDP_HOST=sandbox
#CHROME_CDP_PORT=9223
#DESKTOP_VNC_URL=

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
